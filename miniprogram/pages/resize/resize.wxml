<view class="container">
  <canvas type="2d" id="imageCanvas" class="hidden-canvas"></canvas>
  
  <view class="card">
    <view class="tool-header">
      <text class="tool-icon">📐</text>
      <text class="tool-title">尺寸调整</text>
    </view>

    <view class="upload-area" bindtap="chooseImage">
      <view wx:if="{{!originalImage}}" class="upload-placeholder">
        <text class="upload-icon">📷</text>
        <text class="upload-text">点击选择图片</text>
      </view>
      <image wx:else class="preview-image" src="{{originalImage}}" mode="widthFix" />
    </view>

    <view class="options-card">
      <text class="option-title">目标尺寸</text>
      <view class="input-row">
        <view class="input-group">
          <text class="input-label">宽度 (px)</text>
          <input class="size-input" type="number" value="{{width}}" placeholder="宽度" bindinput="onWidthInput" />
        </view>
        <view class="input-group">
          <text class="input-label">高度 (px)</text>
          <input class="size-input" type="number" value="{{height}}" placeholder="高度" bindinput="onHeightInput" />
        </view>
      </view>
      <view class="ratio-btns">
        <view class="ratio-btn {{selectedRatio == '1:1' ? 'active' : ''}}" bindtap="setRatio" data-ratio="1:1">1:1</view>
        <view class="ratio-btn {{selectedRatio == '4:3' ? 'active' : ''}}" bindtap="setRatio" data-ratio="4:3">4:3</view>
        <view class="ratio-btn {{selectedRatio == '16:9' ? 'active' : ''}}" bindtap="setRatio" data-ratio="16:9">16:9</view>
        <view class="ratio-btn {{selectedRatio == '9:16' ? 'active' : ''}}" bindtap="setRatio" data-ratio="9:16">9:16</view>
      </view>
      <view class="aspect-toggle">
        <text class="toggle-label">保持比例</text>
        <switch class="toggle-switch" checked="{{keepAspect}}" bindchange="onAspectChange" />
      </view>
    </view>

    <view wx:if="originalImage" class="action-area">
      <view class="btn-primary action-btn" bindtap="resizeImage">
        <text class="btn-text">调整尺寸</text>
      </view>
    </view>

    <view wx:if="processedImage" class="result-area">
      <text class="result-title">调整结果</text>
      <image class="result-image" src="{{processedImage}}" mode="widthFix" />
      <view class="result-info">
        <text class="info-text">原尺寸: {{originalWidth}}×{{originalHeight}}</text>
        <text class="info-text">新尺寸: {{width}}×{{height}}</text>
      </view>
      <view class="result-actions">
        <view class="btn-secondary" bindtap="saveImage">
          <text class="btn-text">保存到相册</text>
        </view>
        <view class="btn-cloud" bindtap="saveToCloud">
          <text class="btn-text">{{savingToCloud ? '上传中...' : '保存到云存储'}}</text>
        </view>
        <view class="btn-secondary" bindtap="reset">
          <text class="btn-text">重新调整</text>
        </view>
      </view>
      <view wx:if="cloudFileID" class="cloud-success">
        <text class="cloud-icon">☁️</text>
        <text class="cloud-text">已保存到云存储，可在「我的」页面查看</text>
      </view>
    </view>
  </view>
</view>