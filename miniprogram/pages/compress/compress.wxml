<view class="container">
  <view class="card">
    <view class="tool-header">
      <text class="tool-icon">📷</text>
      <text class="tool-title">图片压缩</text>
    </view>

    <view class="upload-area" bindtap="chooseImage">
      <view wx:if="{{!originalImage}}" class="upload-placeholder">
        <text class="upload-icon">📷</text>
        <text class="upload-text">点击选择图片</text>
      </view>
      <image wx:else class="preview-image" src="{{originalImage}}" mode="widthFix" />
    </view>

    <view class="options-card">
      <text class="option-title">压缩质量</text>
      <view class="slider-container">
        <text class="slider-label">低</text>
        <slider class="quality-slider" value="{{quality}}" min="10" max="100" step="5" bindchange="onQualityChange" />
        <text class="slider-label">高</text>
      </view>
      <view class="quality-presets">
        <view class="preset-btn {{quality == 90 ? 'active' : ''}}" bindtap="setQuality" data-value="90">高</view>
        <view class="preset-btn {{quality == 70 ? 'active' : ''}}" bindtap="setQuality" data-value="70">中</view>
        <view class="preset-btn {{quality == 50 ? 'active' : ''}}" bindtap="setQuality" data-value="50">低</view>
      </view>
    </view>

    <view wx:if="originalImage" class="action-area">
      <view class="btn-primary action-btn" bindtap="compressImage">
        <text class="btn-text">开始压缩</text>
      </view>
    </view>

    <view wx:if="processedImage" class="result-area">
      <text class="result-title">压缩结果</text>
      <image class="result-image" src="{{processedImage}}" mode="widthFix" />
      <view class="result-info">
        <text class="info-text">原大小: {{originalSize}}</text>
        <text class="info-text">新大小: {{processedSize}}</text>
        <text class="info-text success">节省: {{savePercent}}%</text>
      </view>
      <view class="result-actions">
        <view class="btn-secondary" bindtap="saveImage">
          <text class="btn-text">保存到相册</text>
        </view>
        <view class="btn-cloud" bindtap="saveToCloud">
          <text class="btn-text">{{savingToCloud ? '上传中...' : '保存到云存储'}}</text>
        </view>
        <view class="btn-secondary" bindtap="reset">
          <text class="btn-text">重新压缩</text>
        </view>
      </view>
      <view wx:if="cloudFileID" class="cloud-success">
        <text class="cloud-icon">☁️</text>
        <text class="cloud-text">已保存到云存储，可在「我的」页面查看</text>
      </view>
    </view>
  </view>
</view>