<view class="container">
  <view class="header">
    <view class="user-info" wx:if="{{userInfo}}">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view class="user-detail">
        <text class="user-name">{{userInfo.nickName}}</text>
        <text class="user-greeting">欢迎使用图片工具</text>
      </view>
    </view>
    <view class="user-info loading-user" wx:else>
      <view class="avatar-placeholder">
        <text class="placeholder-icon">👤</text>
      </view>
      <view class="user-detail">
        <text class="loading-text">加载中...</text>
      </view>
    </view>
  </view>

  <view class="tools-section">
    <view class="section-header">
      <text class="section-title">图片工具</text>
      <text class="section-subtitle">轻量高效，即用即走</text>
    </view>

    <view class="tools-grid">
      <view class="tool-item {{item.available ? '' : 'unavailable'}}" wx:for="{{tools}}" wx:key="id" bindtap="goToTool" data-tool="{{item.id}}">
        <view class="tool-icon" style="background: {{item.color}}">
          <text class="icon-text">{{item.icon}}</text>
          <view wx:if="{{!item.available}}" class="coming-soon-badge">
            <text class="badge-text">开发中</text>
          </view>
        </view>
        <text class="tool-name">{{item.name}}</text>
        <text wx:if="{{!item.available}}" class="tool-status">敬请期待</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="copyright">© 2024 图片工具 | 版本 {{version}}</text>
  </view>
</view>