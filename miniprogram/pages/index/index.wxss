.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  color: #ffffff;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 48rpx;
}

.user-detail {
  margin-left: 24rpx;
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-greeting {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
}

.loading-text {
  font-size: 30rpx;
  opacity: 0.8;
}

.tools-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.section-subtitle {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f9fa;
  transition: all 0.2s;
}

.tool-item:active {
  transform: scale(0.95);
}

.tool-item.unavailable {
  opacity: 0.5;
}

.tool-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  position: relative;
}

.icon-text {
  font-size: 48rpx;
}

.coming-soon-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: #ff5722;
  border-radius: 20rpx;
  padding: 4rpx 12rpx;
}

.badge-text {
  font-size: 18rpx;
  color: #ffffff;
}

.tool-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.tool-status {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}

.copyright {
  font-size: 24rpx;
  color: #cccccc;
}