.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  display: flex;
  align-items: center;
  flex: 1;
}

.setting-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.setting-text {
  font-size: 30rpx;
  color: #333333;
}

.setting-value {
  display: flex;
  align-items: center;
}

.cache-size {
  font-size: 26rpx;
  color: #999999;
  margin-right: 12rpx;
}

.setting-switch {
  transform: scale(0.8);
}

.setting-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.version-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.version-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.copyright {
  font-size: 24rpx;
  color: #cccccc;
}