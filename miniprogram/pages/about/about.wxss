.container {
  padding: 20rpx;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.about-header {
  text-align: center;
}

.app-name {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.app-version {
  font-size: 26rpx;
  color: #999999;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 24rpx;
  display: block;
}

.feature-list {
  display: flex;
  flex-wrap: wrap;
}

.feature-item {
  width: calc(50% - 10rpx);
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.feature-icon {
  font-size: 32rpx;
}

.feature-text {
  font-size: 26rpx;
  color: #666666;
}

.terms-content {
  padding-left: 20rpx;
}

.terms-text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.contact-info {
  padding-left: 20rpx;
}

.contact-text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.contact-email {
  font-size: 26rpx;
  color: #1a73e8;
}

.footer {
  text-align: center;
  padding: 30rpx 0;
}

.copyright {
  font-size: 24rpx;
  color: #999999;
}

@media (prefers-color-scheme: dark) {
  .card {
    background: #2d2d2d;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
  }
  
  .app-name {
    color: #ffffff;
  }
  
  .section-title {
    color: #e0e0e0;
  }
  
  .feature-text {
    color: #cccccc;
  }
  
  .terms-text {
    color: #cccccc;
  }
  
  .contact-text {
    color: #cccccc;
  }
}