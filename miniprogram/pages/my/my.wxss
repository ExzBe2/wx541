.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.avatar-area {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 56rpx;
}

.user-info {
  flex: 1;
  margin-left: 24rpx;
}

.user-name {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
}

.action-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.auth-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  background: #ffffff;
  border: 2rpx solid #1a73e8;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.auth-btn::after {
  display: none;
}

.auth-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.auth-text {
  font-size: 24rpx;
  color: #1a73e8;
}

.stats-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 600;
  color: #1a73e8;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e5e5e5;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 10rpx 0;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  padding: 20rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.loading {
  padding: 60rpx;
  text-align: center;
  color: #999999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

.image-list {
  padding: 10rpx 20rpx;
}

.image-item {
  display: flex;
  align-items: center;
  padding: 20rpx 10rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.image-item:last-child {
  border-bottom: none;
}

.image-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

.image-info {
  flex: 1;
  margin-left: 20rpx;
}

.image-tool {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 6rpx;
}

.image-date {
  font-size: 24rpx;
  color: #999999;
}

.image-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #1a73e8;
  padding: 8rpx 16rpx;
  background: #f0f5ff;
  border-radius: 8rpx;
}

.action-btn.delete {
  color: #ea4335;
  background: #fff0f0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}

.copyright {
  font-size: 24rpx;
  color: #cccccc;
}